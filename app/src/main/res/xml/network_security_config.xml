<?xml version="1.0" encoding="utf-8"?>
<!--
    Kipita network security config — enforces HTTPS for all traffic.
    Dev flavor overrides this file to permit cleartext to localhost (10.0.2.2).
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">kipita.app</domain>
        <!-- Google APIs -->
        <domain includeSubdomains="true">places.googleapis.com</domain>
        <domain includeSubdomains="true">maps.googleapis.com</domain>
        <domain includeSubdomains="true">generativelanguage.googleapis.com</domain>
        <!-- Crypto price feeds -->
        <domain includeSubdomains="true">api.coingecko.com</domain>
        <domain includeSubdomains="true">api.coinbase.com</domain>
        <domain includeSubdomains="true">api.gemini.com</domain>
        <domain includeSubdomains="true">api.kraken.com</domain>
        <domain includeSubdomains="true">api.coincap.io</domain>
        <domain includeSubdomains="true">api.frankfurter.app</domain>
        <!-- BTCMap merchants -->
        <domain includeSubdomains="true">api.btcmap.org</domain>
        <!-- Dwaat travel backend -->
        <domain includeSubdomains="true">api.dwaat.com</domain>
        <domain includeSubdomains="true">dwaat.com</domain>
        <!-- Wallet / River -->
        <domain includeSubdomains="true">app.river.com</domain>
    </domain-config>
</network-security-config>
